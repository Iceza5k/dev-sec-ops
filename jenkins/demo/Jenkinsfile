def installNodeDeps(String targetDir) {
  dir(targetDir) {
    if (fileExists('package-lock.json')) {
      sh 'npm ci'
    } else {
      sh 'npm install'
    }
  }
}

def runNodeTestsIfPresent(String targetDir) {
  dir(targetDir) {
    int hasTestScript = sh(
      script: "node -e \"const pkg=require('./package.json'); process.exit(pkg.scripts && pkg.scripts.test ? 0 : 1)\"",
      returnStatus: true
    )

    if (hasTestScript == 0) {
      sh 'npm test -- --ci || npm test'
    } else {
      echo "No test script found in ${targetDir}/package.json. Skipping tests."
    }
  }
}

pipeline {
  agent {
    kubernetes {
      yaml '''
      apiVersion: v1
      kind: Pod
      spec:
        containers:
        # Node.js container for npm install and tests
        - name: nodejs
          image: node:20-bullseye-slim
          command:
          - cat
          tty: true
        
        # Sonar Scanner container
        - name: sonar
          image: sonarsource/sonar-scanner-cli:latest
          command:
          - cat
          tty: true

        # Docker CLI container
        - name: docker-cli
          image: docker:cli
          command:
          - cat
          tty: true
          volumeMounts:
          - mountPath: /var/run/docker.sock
            name: docker-sock
        
        # Trivy scan container
        - name: trivy
          image: aquasec/trivy:0.69.3
          command:
          - cat
          tty: true
          volumeMounts:
          - mountPath: /var/run/docker.sock 
            name: docker-sock
        
        # Container for API requests
        - name: curl
          image: alpine:latest
          command:
          - cat
          tty: true

        volumes:
        - name: docker-sock
          hostPath:
            path: /var/run/docker.sock
      '''
    }
  }

  options {
    disableConcurrentBuilds()
  }

  parameters {
    booleanParam(name: 'PUSH_TO_HARBOR', defaultValue: false, description: 'Push the built image to Harbor')
    booleanParam(name: 'IMPORT_TO_DEFECTDOJO', defaultValue: false, description: 'Upload the Trivy report to DefectDojo')
  }

  environment {
    REPO_URL = 'https://github.com/docker/getting-started-todo-app.git'
    REPO_BRANCH = 'main'

    APP_NAME = 'getting-started-todo-app'
    IMAGE_TAG = "${env.BUILD_NUMBER}"
    REGISTRY_URL = 'harbor.local:30002'
    REGISTRY_PROJECT = 'my-project'
    IMAGE_NAME = "${REGISTRY_URL}/${REGISTRY_PROJECT}/${APP_NAME}:${IMAGE_TAG}"

    SONAR_ORGANIZATION = 'tanut-pen'
    SONARQUBE_URL = 'https://sonarcloud.io'
    SONARQUBE_ENV = 'sonarqube'
    SONAR_PROJECT_KEY = 'docker-getting-started-todo-app'
    SONAR_PROJECT_NAME = 'docker-getting-started-todo-app'

    HARBOR_CREDENTIALS_ID = 'harbor-credentials'
    DEFECTDOJO_URL = 'http://defectdojo-django.defectdojo.svc.cluster.local'
    DEFECTDOJO_ENGAGEMENT_ID = '1'
    DEFECTDOJO_PRODUCT_NAME = 'getting-started-todo-app'
    DEFECTDOJO_API_TOKEN = credentials('defectdojo-api-token')

  }

  stages {
    stage('Clone Repository') {
      steps {
        deleteDir()
        git branch: "${env.REPO_BRANCH}", url: "${env.REPO_URL}"
      }
    }

    stage('Install Dependencies') {
      steps {
        // Run dependency installation in the nodejs container.
        container('nodejs') {
          script {
            installNodeDeps('client')
            installNodeDeps('backend')
          }
        }
      }
    }

    stage('Run Tests') {
      steps {
        container('nodejs') {
          script {
            runNodeTestsIfPresent('client')
            runNodeTestsIfPresent('backend')
          }
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        // Use the nodejs container so scanner installation and Node runtime match.
        container('nodejs') {
          withSonarQubeEnv('sonarqube') {
          withCredentials([string(credentialsId: 'sonar', variable: 'SONAR_TOKEN')]) {
            sh '''
              # Install sonar-scanner through npm.
              npm install -g sonarqube-scanner

              # Detect the Node.js executable path.
              NODE_EXEC=$(which node)
              
              # Run the scan with the detected Node.js binary.
              sonar-scanner \
                -Dsonar.host.url=${SONARQUBE_URL} \
                -Dsonar.login=$SONAR_TOKEN \
                -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                -Dsonar.projectName=$SONAR_PROJECT_NAME \
                -Dsonar.organization=$SONAR_ORGANIZATION \
                -Dsonar.projectVersion=$BUILD_NUMBER \
                -Dsonar.sources=backend,client \
                -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/coverage/** \
                -Dsonar.sourceEncoding=UTF-8 \
                -Dsonar.nodejs.executable=$NODE_EXEC

              # Export SonarQube issues to JSON for DefectDojo import
              curl -s -u $SONAR_TOKEN: ${SONARQUBE_URL}/api/issues/search?projectKeys=$SONAR_PROJECT_KEY&resolved=false&ps=500 > sonar-report.json
            '''
          }
        }
        }
      }
    }

    stage('Import SonarQube to DefectDojo') {
      steps {
        container('curl') {
          sh '''
            apk add -q curl

            RESPONSE=$(curl -sS --connect-timeout 10 -m 60 \
              -X POST "${DEFECTDOJO_URL}/api/v2/import-scan/" \
              -H "Authorization: Token ${DEFECTDOJO_API_TOKEN}" \
              -H "Accept: application/json" \
              -F "scan_type=SonarQube Scan" \
              -F "engagement=${DEFECTDOJO_ENGAGEMENT_ID}" \
              -F "product_name=${DEFECTDOJO_PRODUCT_NAME}" \
              -F "active=true" \
              -F "verified=false" \
              -F "close_old_findings=false" \
              -F "scan_date=$(date +%F)" \
              -F "minimum_severity=Info" \
              -F "file=@sonar-report.json" \
              -w "\nHTTP_STATUS:%{http_code}")

            echo "=== SONARQUBE IMPORT RESPONSE ==="
            echo "$RESPONSE"
          '''
        }
      }
    }

    // stage('Quality Gate') {
    //   steps {
    //     timeout(time: 10, unit: 'MINUTES') {
    //       waitForQualityGate abortPipeline: true
    //     }
    //   }
    // }

    stage('Build Container Image') {
      steps {
        container('docker-cli') {
          // Use double quotes so Groovy expands the variable.
          sh "docker build -t ${IMAGE_NAME} ."
        }
      }
    }

    stage('Vulnerability Scan') {
    steps {
        container('trivy') {
            script {
                // Define the dynamic image name (usually derived from previous build steps)
                def imageName = "harbor.local:30002/my-project/getting-started-todo-app:${env.BUILD_NUMBER}"
                
                echo "Scanning Image: ${imageName}"

                // 1. Generate HTML Report for Jenkins Artifacts
                sh "trivy image --format template --template '@/contrib/html.tpl' --output trivy-report.html --severity HIGH,CRITICAL ${imageName}"

                // 2. Generate JSON Report for DefectDojo
                sh "trivy image --format json --output trivy-report.json --severity HIGH,CRITICAL ${imageName}"
            }
        }
    }
}

    stage('Push Image to Harbor') {
      when {
        expression { return params.PUSH_TO_HARBOR }
      }
      steps {
        container('docker-cli') {
          withCredentials([usernamePassword(credentialsId: "${env.HARBOR_CREDENTIALS_ID}", usernameVariable: 'HARBOR_USER', passwordVariable: 'HARBOR_PASS')]) {
            sh """
              echo "${HARBOR_PASS}" | docker login ${REGISTRY_URL} -u "${HARBOR_USER}" --password-stdin
              docker push ${IMAGE_NAME}
              docker logout ${REGISTRY_URL}
            """
          }
        }
      }
    }


    stage('Import Scan to DefectDojo') {
      when {
        expression { return params.IMPORT_TO_DEFECTDOJO }
      }
      steps {
        container('curl') {
          sh '''
  apk add -q curl

  RESPONSE=$(curl -sS --connect-timeout 10 -m 60 \
    -X POST "${DEFECTDOJO_URL}/api/v2/import-scan/" \
    -H "Authorization: Token ${DEFECTDOJO_API_TOKEN}" \
    -H "Accept: application/json" \
    -F "scan_type=Trivy Scan" \
    -F "engagement=${DEFECTDOJO_ENGAGEMENT_ID}" \
    -F "product_name=${DEFECTDOJO_PRODUCT_NAME}" \
    -F "active=true" \
    -F "verified=false" \
    -F "close_old_findings=false" \
    -F "scan_date=$(date +%F)" \
    -F "minimum_severity=Low" \
    -F "file=@trivy-report.json" \
    -w "\nHTTP_STATUS:%{http_code}")

  echo "=== RESPONSE BODY ==="
  echo "$RESPONSE"
'''
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'trivy-report.json,sonar-report.json', allowEmptyArchive: true
    }
  }
}
