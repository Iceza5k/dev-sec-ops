pipeline {
  agent {
    kubernetes {
      yaml '''
      apiVersion: v1
      kind: Pod
      spec:
        serviceAccountName: jenkins
        containers:
        # Docker CLI container for building and pushing the image
        - name: docker-cli
          image: docker:cli
          command:
          - cat
          tty: true
          volumeMounts:
          - mountPath: /var/run/docker.sock
            name: docker-sock
        
        # Git container for modifying manifests and pushing back to git
        - name: git
          image: alpine/git:latest
          command:
          - cat
          tty: true
        
        # Argo CD CLI container to trigger application sync
        - name: argocd-cli
          image: quay.io/argoproj/argocd:v2.10.4
          command:
          - cat
          tty: true

        volumes:
        - name: docker-sock
          hostPath:
            path: /var/run/docker.sock
      '''
    }
  }

  options {
    disableConcurrentBuilds()
    timeout(time: 15, unit: 'MINUTES')
  }

  environment {
    REGISTRY_URL = 'harbor.tpinf.xyz'
    REGISTRY_PROJECT = 'lab'
    IMAGE_NAME = 'devops-dashboard'
    FULL_IMAGE_NAME = "${REGISTRY_URL}/${REGISTRY_PROJECT}/${IMAGE_NAME}:build-${env.BUILD_NUMBER}"
    
    HARBOR_CREDENTIALS_ID = 'harbor-credentials'
    GIT_CREDENTIALS_ID = 'tanut-pen'
    GIT_REPO_URL = 'https://github.com/tanut-pen/dev-sec-ops.git'
  }

  stages {
    stage('Clone Repository') {
      steps {
        deleteDir()
        checkout scm
      }
    }

    stage('Build Container Image') {
      steps {
        container('docker-cli') {
          sh "docker build -t ${FULL_IMAGE_NAME} ./devops-dashboard"
        }
      }
    }

    stage('Push Image to Harbor') {
      steps {
        container('docker-cli') {
          withCredentials([usernamePassword(credentialsId: "${env.HARBOR_CREDENTIALS_ID}", usernameVariable: 'HARBOR_USER', passwordVariable: 'HARBOR_PASS')]) {
            sh """
              echo "${HARBOR_PASS}" | docker login ${REGISTRY_URL} -u "${HARBOR_USER}" --password-stdin
              docker push ${FULL_IMAGE_NAME}
              docker logout ${REGISTRY_URL}
            """
          }
        }
      }
    }

    stage('Update Manifest Image Tag') {
      steps {
        container('git') {
          sh """
            # Update the image tag in deployment.yaml
            sed -i 's|image: devops-dashboard:.*|image: ${FULL_IMAGE_NAME}|' devops-dashboard/manifests/deployment.yaml
            
            # Print updated manifest section for logs
            grep "image:" devops-dashboard/manifests/deployment.yaml
          """
        }
      }
    }

    stage('Commit and Push to Git') {
      steps {
        container('git') {
          withCredentials([usernamePassword(credentialsId: "${env.GIT_CREDENTIALS_ID}", usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
            sh '''
              # Bypass Git directory ownership security checks between root/jenkins users
              git config --global --add safe.directory '*'

              git config user.name "Jenkins CI"
              git config user.email "jenkins@tpinf.xyz"
              
              git add devops-dashboard/manifests/deployment.yaml
              
              # Commit tag update. Avoid infinite loop by using [skip ci] in commit message
              git commit -m "chore(ops): update devops-dashboard image tag to build-${BUILD_NUMBER} [skip ci]" || echo "No changes to commit"
              
              # Set credentials in origin remote and push using shell-masked variables
              git remote set-url origin "https://${GIT_USER}:${GIT_PASS}@github.com/tanut-pen/dev-sec-ops.git"
              git push origin HEAD:main
            '''
          }
        }
      }
    }

    stage('Argo CD Sync') {
      steps {
        // Fetch the Argo CD admin password using the ServiceAccount credentials
        container('git') {
          sh '''
            apk add --no-cache -q curl jq
            TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
            
            # Fetch the secret via HTTP from the Kubernetes API server
            curl -sSk -H "Authorization: Bearer $TOKEN" \
              https://kubernetes.default.svc/api/v1/namespaces/argocd/secrets/argocd-initial-admin-secret | \
              jq -r '.data.password' | base64 -d > argocd-password.txt
          '''
        }
        
        // Log in to Argo CD and run sync
        container('argocd-cli') {
          sh '''
            ARGOCD_PASSWORD=$(cat argocd-password.txt)
            argocd login argocd-server.argocd.svc.cluster.local --insecure --username admin --password "$ARGOCD_PASSWORD"
            argocd app sync devops-dashboard
            rm -f argocd-password.txt
          '''
        }
      }
    }
  }
}
