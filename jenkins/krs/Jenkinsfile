pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: python
    image: python:3.12-slim
    command:
    - cat
    tty: true
'''
        }
    }
    stages {
        stage('Render Batch Config') {
            steps {
                // Explicitly tell Jenkins to run these steps inside the 'python' container
                container('python') {
                    withCredentials([
                      file(credentialsId: 'krs-batch-secret-yaml', variable: 'BATCH_SECRET_FILE')
                    ]) {
                      sh '''
                        apt-get update && apt-get install -y gettext-base > /dev/null
                        mkdir -p /tmp/krs-batch
                        PY=$(command -v python3 || command -v python || true)
                        if [ -z "$PY" ]; then
                          echo "ERROR: Python is required to parse the secret YAML file" >&2
                          exit 1
                        fi
                        eval "$($PY - <<'PY'
                        import os, shlex
                        path = os.environ['BATCH_SECRET_FILE']
                        vars = {}
                        with open(path, 'r') as f:
                            for line in f:
                                line = line.strip()
                                if not line or line.startswith('#'):
                                    continue
                                if ':' not in line:
                                    continue
                                key, value = line.split(':', 1)
                                key = key.strip()
                                value = value.strip()
                                if len(value) >= 2 and value[0] == value[-1] and value[0] in ('"', "'"):
                                    value = value[1:-1]
                                vars[key] = value
                        for k, v in vars.items():
                            print('export %s=%s' % (k, shlex.quote(v)))
                        PY
                        )"
                        envsubst < ${service}/config/application-dc-template.yaml > /tmp/krs-batch/application-dc.yaml
                        envsubst < ${service}/config/application-dr-template.yaml > /tmp/krs-batch/application-dr.yaml
                        cat /tmp/krs-batch/application-dr.yaml
                      '''
                    }
                }
            }
        }
        stage('Deploy Batch') {
            steps {
                script  {
                    // Note: If you need 'ssh' for this step, ensure the container running this step has it installed. 
                    // By default, this will run in the 'jnlp' container.
                    sh "ssh echo hi"
                }
            }
        }
    }
}